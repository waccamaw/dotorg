.DS_Store
._*
.hugo_build.lock
public/
.env

# Ignore Micro.blog synced content (blog posts by date)
content/20*/
content/replies/

# But allow static content files
!content/*.md
!content/redirects/

apps/**

content-export*
content.zip
*.zip

content/
# Micro.blog syncs data/ (blogrolls, bookshelves, …) — ignore those,
# but keep hand-authored config like the Pauwau date in the repo.
data/*
!data/pauwau.toml
.session-cookie

# Python cache
__pycache__/
*.pyc
*.pyo

# Node
node_modules/

# Backups
backups/